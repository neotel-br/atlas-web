{
  "name": "atlas-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "fumadocs-mdx && next build",
    "dev": "next dev",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "echo skip",
    "lint": "eslint",
    "watch:docs": "chokidar \"content/docs/**\" -c \"npm run build\""
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.8.5",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-ui": "16.8.5",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.13",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
