# syntax=docker/dockerfile:1
FROM node:22-alpine
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
COPY package.json package-lock.json ./
# --ignore-scripts: skip the fumadocs-mdx postinstall here (source.config.ts is not
# copied yet); the .source map is regenerated by the createMDX plugin on `next dev`.
RUN npm ci --ignore-scripts
COPY . .
EXPOSE 3000
CMD ["npm", "run", "dev"]
